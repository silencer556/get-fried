# Copy this file to .env and fill in real values before deploying.
#   cp .env.example .env
# docker-compose reads these. Do NOT commit your real .env (it's gitignored).

# Host port to reach the app on (http://<server-ip>:<HOST_PORT>). Change this if
# another Umbrel app already uses 3000. The container always listens on 3000.
HOST_PORT=3000

# Password for the editor role (full create/edit/delete). Choose something strong.
EDITOR_PASSWORD=change-me-editor

# Password for the read-only viewer role (can browse + run timers, not edit).
VIEWER_PASSWORD=change-me-viewer

# Secret used to sign login sessions. Generate a long random string, e.g.:
#   openssl rand -hex 32
# If left unset, a new one is generated on every restart and everyone is logged out.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Phase 2c (Web Push) — background timer alerts ---
# Generate ONE keypair and reuse it everywhere (dev + prod). Easiest:
#   npx web-push generate-vapid-keys
# Then paste the two values here. VAPID_SUBJECT is a contact URL/mailto.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Phase 2b (Cloudflare Tunnel) — only if using the compose cloudflared sidecar ---
# We're using the existing Umbrel Cloudflare Tunnel app instead, so this stays blank.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Backups (Backblaze B2 via rclone) ---
# Nightly backup of the SQLite DB + uploaded photos. Create a B2 application key
# SCOPED TO ONE BUCKET (least privilege). Bucket name is CASE-SENSITIVE and must
# match the Backblaze dashboard exactly.
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
# Optional tuning:
# BACKUP_SCHEDULE=0 2 * * *      # cron (uses TZ below); default 2 AM
# BACKUP_RETENTION_DAYS=30       # prune db snapshots older than this; 0 = keep all
# BACKUP_RUN_ON_START=1          # run one backup immediately on start (handy for testing)
# TZ=America/New_York            # local time for the schedule (default UTC)
